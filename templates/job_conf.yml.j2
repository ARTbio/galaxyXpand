---
# This file is managed by Ansible.
# Do not edit this file manually. Any changes will be automatically reverted.

runners:
{% if job_destinations.values() | selectattr('runner', 'defined') | selectattr('runner', 'equalto', 'local_runner') | list | length > 0 %}
  local_runner:
    load: galaxy.jobs.runners.local:LocalJobRunner
{% endif %}
  slurm:
    load: galaxy.jobs.runners.slurm:SlurmJobRunner
    drmaa_library_path: /usr/lib/slurm-drmaa/lib/libdrmaa.so.1

handling:
  assign:
    - db-skip-locked

execution:
  default: {{ job_default_destination }}
  environments:
{% for dest, params in job_destinations.items() %}
{% set runner = params.runner | default('slurm') %}
    {{ dest }}:
      runner: {{ runner }}
{% if runner == 'local_runner' %}
{% if params.tmp_dir | default(false) %}
      tmp_dir: true
{% endif %}
{% else %}
      nativeSpecification: "--partition=debug --ntasks={{ params.ntasks | default(1) }}{% if params.mem is defined %} --mem={{ params.mem }}{% endif %}"
{% if params.env is defined %}
      env:
{% for env_var in params.env %}
        - name: '{{ env_var.name }}'
          value: '{{ env_var.value }}'
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}

limits:
  - type: anonymous_user_concurrent_jobs
    value: '{{ job_limits_anonymous }}'
  - type: registered_user_concurrent_jobs
    value: '{{ job_limits_registered }}'
{% for limit in job_limits_environment_total | default([]) %}
  - type: environment_total_concurrent_jobs
    id: {{ limit.id }}
    value: {{ limit.value }}
{% endfor %}
{% for limit in job_limits_environment_user | default([]) %}
  - type: environment_user_concurrent_jobs
    id: {{ limit.id }}
    value: {{ limit.value }}
{% endfor %}

tools:
{% for tool in job_tool_routing %}
{% if tool.class is defined %}
  - class: {{ tool.class }}
    environment: {{ tool.environment }}
{% else %}
  - id: "{{ tool.id }}"
    destination: "{{ tool.destination }}"
{% endif %}
{% endfor %}
