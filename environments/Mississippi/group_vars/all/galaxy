---
# Galaxy
galaxy_manage_cleanup: yes  # Install a cron job to clean up Galaxy framework and job execution temporary
galaxy_tool_dependency_dir: "{{ galaxy_root }}/tool_dependencies"

galaxy_config:
  gravity:
    gunicorn:
      # performance options
      workers: 4 # web traffic. likely enough for Mississippi
    handlers:
      job_handlers:
        pools:
          - job-handlers
        processes: 4 # likely enough for Mississippi
    celery:
      workers: 2  # eg workflow scheduling

  galaxy:
    brand: "🧬 Mississippi[2]"
    admin_users: "{{ vault_admin_users }}"
    smtp_username: "{{ vault_smtp_username }}"
    smtp_password: "{{ vault_smtp_password }}"
    error_email_to: "{{ vault_error_email_to }}"
    email_from: "{{ vault_email_from }}"
    smtp_server: "smtp.gmail.com:587"
    id_secret: "{{ vault_id_secret }}"
    require_login: true
    # Miscellaneous
    ftp_upload_dir: /home/galaxy/galaxy/database/ftp
    ftp_upload_site: ftp://134.157.183.152
    # default len_file_path: shared/ucsc/chrom
    len_file_path: /home/galaxy/galaxy/config/len
    tool_data_table_config_path: /home/galaxy/galaxy/config/tool_data_table_conf.xml

# Welcome html page variables
_Mississippi_info: |
  <strong>Galaxy is now running
  <br>
  release_25.1 (Dec 2025)</strong>
Mississippi_info: "{{ _Mississippi_info | indent(width=12, first=True) }}"

# deploy galaxy configuration files
galaxy_config_files:
  - src: "{{ inventory_dir }}/files/galaxy/config/job_conf.yml"
    dest: "{{ galaxy_config_dir }}/job_conf.yml"
  - src: "{{ inventory_dir }}/files/galaxy/html/images/ARTbio_mississippi_screen.jpg"
    dest: "{{ galaxy_server_dir }}/static/images/ARTbio_mississippi_screen.jpg"
  - src: "{{ inventory_dir }}/files/galaxy/html/images/IBPS_logo.jpg"
    dest: "{{ galaxy_server_dir }}/static/images/IBPS_logo.jpg"
  - src: "{{ inventory_dir }}/files/galaxy/html/images/mississippi_logo.png"
    dest: "{{ galaxy_server_dir }}/static/images/mississippi_logo.png"

galaxy_config_templates:
  - src: "{{ inventory_dir }}/templates/html/welcome.html.j2"
    dest: "{{ galaxy_server_dir }}/static/welcome.html"
